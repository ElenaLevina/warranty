{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Warranty session metadata",
  "type": "object",
  "required": ["case_id", "plate_number", "session_start", "session_end", "mechanic_id", "files", "description", "status"],
  "properties": {
    "case_id": {
      "type": "string",
      "description": "Уникальный id кейса = имя папки: <номер>_<YYYYMMDD-HHMMSS>_<rand>. Допускает несколько кейсов на один номер.",
      "examples": ["123-45-678_20260525-091400_a3f"]
    },
    "plate_number": {
      "type": "string",
      "description": "Отформатированный израильский номер с дефисами",
      "pattern": "^(\\d{3}-\\d{2}-\\d{3}|\\d{2}-\\d{3}-\\d{2})$",
      "examples": ["123-45-678", "12-345-67"]
    },
    "session_start": { "type": "string", "format": "date-time", "examples": ["2026-05-25T09:14:00"] },
    "session_end": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "null пока status=open; заполняется при закрытии",
      "examples": ["2026-05-25T09:31:00"]
    },
    "mechanic_id": { "type": "string", "examples": ["user_042"] },
    "device_id": {
      "type": "string",
      "description": "Стабильный per-install id устройства, записавшего кейс (§8). Необязательное поле.",
      "examples": ["dev_1a2b3c4d5e6f"]
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "timestamp"],
        "properties": {
          "name": { "type": "string", "examples": ["plate.jpg", "photo_001.jpg", "video_001.mp4"] },
          "type": { "type": "string", "enum": ["photo", "video"] },
          "timestamp": { "type": "string", "examples": ["09:14:22"] },
          "duration_sec": { "type": "integer", "description": "только для type=video", "minimum": 0, "maximum": 180 }
        }
      }
    },
    "description": { "type": "string", "description": "описание повреждений, вводит механик" },
    "status": { "type": "string", "enum": ["open", "closed"] }
  }
}
